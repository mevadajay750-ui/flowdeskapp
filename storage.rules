rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == "admin";
    }

    function isApprovedUser() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).status == "approved";
    }

    function projectData(projectId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId)).data;
    }

    function isProjectMemberFor(projectId) {
      let projectPath = /databases/(default)/documents/projects/$(projectId);
      let project = projectData(projectId);

      // Project membership is determined from the denormalized memberIds array.
      // createdBy is a fallback for legacy projects missing memberIds.
      return isSignedIn()
        && firestore.exists(projectPath)
        && (
          (project.memberIds != null && request.auth.uid in project.memberIds)
          || project.createdBy == request.auth.uid
        );
    }

    function canAccessProjectFiles(projectId) {
      return isApprovedUser() && (isAdmin() || isProjectMemberFor(projectId));
    }

    function isChatRoomParticipantFor(chatRoomId) {
      let roomPath = /databases/(default)/documents/chatRooms/$(chatRoomId);

      return isSignedIn()
        && firestore.exists(roomPath)
        && firestore.get(roomPath).data.participantIds != null
        && request.auth.uid in firestore.get(roomPath).data.participantIds;
    }

    function isGroupAdminFor(chatRoomId) {
      let roomPath = /databases/(default)/documents/chatRooms/$(chatRoomId);

      return isSignedIn()
        && firestore.exists(roomPath)
        && firestore.get(roomPath).data.admins != null
        && request.auth.uid in firestore.get(roomPath).data.admins;
    }

    // Project chat attachments (legacy)
    match /projects/{projectId}/chat/{messageId} {
      allow read, write: if canAccessProjectFiles(projectId);
    }

    // Unified chat room attachments
    match /chatRooms/{chatRoomId}/chat/{messageId} {
      allow read, write: if isApprovedUser() && (isAdmin() || isChatRoomParticipantFor(chatRoomId));
    }

    // User uploads
    match /users/{uid}/id-proof {
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /users/{uid}/profile-photo {
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /chat-groups/{chatRoomId}/avatar {
      allow write: if isApprovedUser() && (isAdmin() || isGroupAdminFor(chatRoomId));
      allow read: if isApprovedUser() && (isAdmin() || isChatRoomParticipantFor(chatRoomId));
    }

    match /projects/{projectId}/files/{itemId}/{fileName} {
      allow read, write: if canAccessProjectFiles(projectId);
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
