rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isProjectMemberFor(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;

      // Project membership is determined from the denormalized memberIds array.
      // All code paths that assign members must keep memberIds in sync.
      return isAuthenticated() &&
        project.memberIds != null &&
        request.auth.uid in project.memberIds;
    }

    function isProjectMember() {
      return isAuthenticated() &&
        resource.data.memberIds != null &&
        request.auth.uid in resource.data.memberIds;
    }

    function isChatRoomParticipantData(room) {
      return isAuthenticated() &&
        room.participantIds != null &&
        request.auth.uid in room.participantIds;
    }

    function isChatRoomMember() {
      return isChatRoomParticipantData(resource.data);
    }

    function isGroupAdmin() {
      return resource.data.type == 'group'
        && resource.data.admins != null
        && request.auth.uid in resource.data.admins;
    }

    function isLastMessageOnlyUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['lastMessage']);
    }

    function isGroupMetadataUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'description', 'avatarUrl', 'participants', 'participantIds', 'admins']);
    }

    function isDirectRoom() {
      return resource.data.type == 'direct';
    }

    function isValidDirectCreate() {
      return request.resource.data.type == 'direct'
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.participants.size() == 2
        && request.resource.data.directKey is string
        && request.resource.data.directKey.size() > 0;
    }

    match /projects/{projectId} {
      // Members can read projects they belong to.
      // Admins can read all projects.
      allow get, list, read: if isAdmin() || isProjectMember();

      allow create, delete: if isAdmin();

      // Admins manage project fields; members may only link an initial chat room.
      allow update: if isAdmin() || (
        isProjectMemberFor(projectId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chatRoomId'])
      );
    }

    match /projects/{projectId}/messages/{messageId} {
      // Legacy project messages (deprecated — use chatRooms)
      allow read: if isAdmin() || isProjectMemberFor(projectId);
      allow create: if isAdmin() || isProjectMemberFor(projectId);
      allow update, delete: if false;
    }

    match /chatRooms/{chatRoomId} {
      allow read: if isChatRoomMember();

      allow create: if request.auth != null
        && request.resource.data.participantIds != null
        && request.auth.uid in request.resource.data.participantIds
        && (request.resource.data.type != 'direct' || isValidDirectCreate())
        && (
          request.resource.data.type != 'group'
          || (
            request.resource.data.type == 'group'
            && request.resource.data.admins != null
            && request.auth.uid in request.resource.data.admins
          )
        );

      // Direct rooms: participants are immutable after creation; only lastMessage may change.
      allow update: if isChatRoomMember() && (
        isLastMessageOnlyUpdate()
        || resource.data.type == 'project'
        || (
          resource.data.type == 'group'
          && isGroupAdmin()
          && isGroupMetadataUpdate()
        )
      ) && !(isDirectRoom() && !isLastMessageOnlyUpdate());

      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isChatRoomParticipantData(
          get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data
        );

        allow update, delete: if false;
      }
    }

    match /users/{userId} {
      // Authenticated users can read profiles (display names in chat, team, etc.).
      allow read: if request.auth != null;

      allow update: if request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      allow create: if request.auth != null;

      allow delete: if false;
    }

    match /timesheets/{timesheetId} {

      allow create: if isAuthenticated();

      allow read: if isAuthenticated()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );

      allow update: if isAuthenticated()
        && (
          (resource.data.userId == request.auth.uid
            && resource.data.status == "pending")
          || isAdmin()
        );

      allow delete: if false;
    }
  }
}

